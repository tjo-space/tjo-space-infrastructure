[Unit]
Description=Jellyseerr container

[Container]
ContainerName=jellyseerr
Image=ghcr.io/fallenbagel/jellyseerr:2.7.3
Network=media.network
User=1010
Group=1010
Volume=/srv/data/fast/jellyseerr:/app/config:rw
AutoUpdate=registry
NoNewPrivileges=true
#PublishPort=5055:5055
IP6=fd6a:e0a3:bb4b:c6b3::19

[Service]
Restart=always
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target default.target
